HTTP_PORT=8081
READ_HEADER_TIMEOUT_SECONDS=5

DATABASE_URL=postgres://postgres:postgres@localhost:5432/datalake?sslmode=disable

INTERNAL_TOKEN=change-me

WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_STALE_AFTER_SECONDS=120
WORKER_MAX_ATTEMPTS=3

# RGW endpoint and admin credentials (Admin Ops API)
RGW_ENDPOINT=http://rook-ceph-rgw-ceph-objectstore.rook-ceph.svc.cluster.local:8080
RGW_ADMIN_PATH=/admin
RGW_REGION=us-east-1
RGW_ACCESS_KEY_ID=
RGW_SECRET_ACCESS_KEY=
RGW_INSECURE_SKIP_VERIFY=false
