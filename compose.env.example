# Docker Compose example environment for non-Kubernetes testing.
# Copy to .env.compose and adjust values for your target environment.

POSTGRES_DB=datalake
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

HTTP_PORT=8081
READ_HEADER_TIMEOUT_SECONDS=5
READY_TIMEOUT_SECONDS=3
LOG_FORMAT=json
LOG_LEVEL=info

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true

DATABASE_URL=postgres://postgres:postgres@postgres:5432/datalake?sslmode=disable

WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_STALE_AFTER_SECONDS=120
WORKER_MAX_ATTEMPTS=3

# RGW endpoint and admin credentials (Admin Ops API)
# Set these to the Ceph RGW reachable from the Docker host / container network.
RGW_ENDPOINT=http://192.168.3.251:7480
RGW_ADMIN_PATH=/admin
RGW_REGION=us-east-1
# Customer-facing S3 endpoint returned by customer-s3-access API.
# Keep this distinct from RGW_ENDPOINT used by the control-plane.
RGW_S3_ADVERTISED_ENDPOINT=http://127.0.0.1:7480
RGW_ACCESS_KEY_ID=replace-me
RGW_SECRET_ACCESS_KEY=replace-me
RGW_INSECURE_SKIP_VERIFY=false
